{
  "name": "bulk-mail-app",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack bulk mail app with React, Express, MongoDB, and Vercel support.",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix client\" \"npm run dev:server\"",
    "dev:server": "node --watch server/index.js",
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "vercel-build": "npm run build --prefix client"
  },
  "keywords": [
    "mern",
    "bulk-mail",
    "vercel"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mongoose": "^8.19.4",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.10",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
